{
  "name": "ohttp-relay",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "mkdir -p dist",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "start": "node --experimental-strip-types src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src test",
    "format": "biome format --write src test"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "hono": "^4.12.25",
    "ohttp-ts": "^0.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@cloudflare/workers-types": "^4.20250224.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.0.0"
  }
}
